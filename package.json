{
  "name": "drizzle-gen",
  "version": "1.0.0",
  "description": "One-shot Drizzle ORM schema table generator — drizzle-gen add <table> -d <dialect>",
  "type": "module",
  "bin": {
    "drizzle-gen": "./dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "commander": "^14.0.0",
    "jiti": "^2.4.0",
    "picocolors": "^1.1.0"
  },
  "peerDependencies": {
    "drizzle-orm": "^1.0.0-rc",
    "zod": "^3.24.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "typebox": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "drizzle-orm": "^1.0.0-rc.4",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typebox": "^1.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "keywords": [
    "drizzle",
    "orm",
    "schema",
    "generator",
    "cli"
  ],
  "license": "MIT"
}
